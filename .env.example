# Template for environment files consumed by docker-compose.yaml.
# Real values for each environment live OUTSIDE this repo:
#   /home/overseer/config/civiclens-prod.env  (used when deploying main)
#   /home/overseer/config/civiclens-dev.env   (used when deploying development)
#
# The deploy workflow picks one or the other based on the branch being pushed.
# Do NOT commit a real .env file — .gitignore blanket-excludes .env*.

# Compose project name. Must be unique per environment.
COMPOSE_PROJECT_NAME=civiclens-prod

# Vite base path. Must start and end with a slash.
# Prod: /      Dev: /develop/
VITE_BASE_PATH=/

# Postgres credentials. The DB_CONN host "db" is the compose service name.
# Set real values in the actual env file (civiclens-{prod,dev}.env outside the repo).
DB_PASSWORD=
DB_CONN=postgresql://postgres:REPLACE_ME@db:5432

# Prod adopts the pre-existing civiclens_pgdata volume via the override
# file docker-compose.prod.yaml (merged in by the deploy workflow on main).
# Dev has no such override — compose auto-creates civiclens-dev_pgdata.
